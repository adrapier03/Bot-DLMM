# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Helius RPC ───────────────────────────────────────────────────────────────
# Single key (legacy)
RPC_URL=https://mainnet.helius-rpc.com/?api-key=
HELIUS_API_KEY=
# Multi-key rotation (comma-separated, direkomendasikan)
HELIUS_API_KEYS=key1,key2,key3,key4,key5

# ─── Jupiter ─────────────────────────────────────────────────────────────────
JUPITER_API_KEY=

# ─── Position Config ─────────────────────────────────────────────────────────
BUDGET_SOL=1
MAX_POSITIONS=1
RANGE_BINS=60

# ─── Filter Token ─────────────────────────────────────────────────────────────
MAX_PRICE_CHANGE_5M=50
MAX_PRICE_CHANGE_1H=300
MIN_POOL_LIQUIDITY=40000
MAX_MC_USD=2000000

# ─── TP / SL ─────────────────────────────────────────────────────────────────
STOP_LOSS_PCT=10
TAKE_PROFIT_PCT=2
EMERGENCY_STOP_LOSS_PCT=17
OUT_OF_RANGE_LIMIT_MIN=30
FEE_CLAIM_THRESHOLD_SOL=0.03

# ─── PnL Stuck ───────────────────────────────────────────────────────────────
PNL_STUCK_THRESHOLD_PCT=1
PNL_STUCK_TIMEOUT_MIN=2

# ─── Auto-Swap ───────────────────────────────────────────────────────────────
AUTO_SWAP=true
MAX_SLIPPAGE_BPS=300

# ─── OOR Limits ──────────────────────────────────────────────────────────────
OOR_ABOVE_LIMIT_MIN=3
OOR_ABOVE_REOPEN_VOL_USD=20000
OOR_ABOVE_MAX_REOPEN=2
OOR_BELOW_LIMIT_MIN=20

# ─── TVL Dilution ────────────────────────────────────────────────────────────
TVL_DILUTED_MIN_HOLD_MIN=45
TVL_DILUTED_THRESHOLD_USD=60000

# ─── Volume Dry ──────────────────────────────────────────────────────────────
VOL_DRY_THRESHOLD_USD=15000
VOL_DRY_CYCLES=3

# ─── Timing ──────────────────────────────────────────────────────────────────
CYCLE_INTERVAL_SEC=20
MONITOR_INTERVAL_SEC=2

# ─── GMGN ────────────────────────────────────────────────────────────────────
GMGN_JSON_PATH=/root/solana-dlmm-project/gmgn-script/gmgn_api_response.json

# ─── Cookin.fun ──────────────────────────────────────────────────────────────
COOKIN_COOKIE=
COOKIN_MIN_SCORE=20
COOKIN_MAX_DUMPERS=60
COOKIN_MAX_BOTS=70
COOKIN_MAX_HOLD_UNDER1MIN=80
COOKIN_MIN_PUMP_CONDITIONS=1
COOKIN_MAX_DUMP_CONDITIONS_PCT=60
