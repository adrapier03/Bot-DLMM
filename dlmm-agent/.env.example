# ─── SECRETS (isi dengan nilai asli kamu) ────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
HELIUS_API_KEY=your_helius_api_key
HELIUS_API_KEYS=key1,key2,key3,key4,key5
JUPITER_API_KEY=your_jupiter_api_key

# Cookin.fun — ambil dari browser DevTools > Application > Cookies > cookin.fun
COOKIN_COOKIE=your__pump_key_cookie_value
COOKIN_VISITOR=your__pump_visitor_cookie_value
COOKIN_GA=your__ga_cookie_value

# GMGN response path (sesuaikan dengan path di server kamu)
GMGN_JSON_PATH=/root/solana-dlmm-project/gmgn-script/gmgn_api_response.json

# ─── POSITION CONFIG ──────────────────────────────────────────────────────────
BUDGET_SOL=1
MAX_POSITIONS=1
RANGE_BINS=60

# ─── FILTER TOKEN (scanner) ───────────────────────────────────────────────────
MAX_PRICE_CHANGE_5M=50
MAX_PRICE_CHANGE_1H=300
MIN_POOL_LIQUIDITY=55000       # Reject pool TVL >= nilai ini (terlalu besar)
MIN_TVL_USD=5000               # Reject pool TVL < nilai ini (terlalu kecil)
MAX_MC_USD=2000000             # Reject token MC >= nilai ini

# ─── TAKE PROFIT / STOP LOSS ─────────────────────────────────────────────────
STOP_LOSS_PCT=10
TAKE_PROFIT_PCT=2
EMERGENCY_STOP_LOSS_PCT=17     # SL paksa meski ada support level
SL_GRACE_PERIOD_MIN=0.5        # Detik pertama setelah open, SL/TP tidak aktif

# ─── PNL STUCK ───────────────────────────────────────────────────────────────
PNL_STUCK_THRESHOLD_PCT=1      # Mulai timer jika PnL nyentuh nilai ini
PNL_STUCK_TIMEOUT_MIN=2        # Close jika stuck selama N menit

# ─── OOR (Out of Range) ───────────────────────────────────────────────────────
OOR_ABOVE_LIMIT_MIN=3          # Close jika OOR pump selama N menit
OOR_ABOVE_REOPEN_VOL_USD=20000 # Re-open jika volume masih >= nilai ini
OOR_ABOVE_MAX_REOPEN=2         # Max re-open berturut-turut
OOR_BELOW_LIMIT_MIN=20         # Close jika OOR dump selama N menit

# ─── VOLUME DRY ──────────────────────────────────────────────────────────────
VOL_DRY_THRESHOLD_USD=10000    # Volume 5m dianggap sepi jika < nilai ini
VOL_DRY_CYCLES=3               # Close setelah N cycle berturut-turut sepi

# ─── TVL MONITORING ──────────────────────────────────────────────────────────
TVL_DILUTED_MIN_HOLD_MIN=45    # Mulai cek TVL setelah hold N menit
TVL_DILUTED_THRESHOLD_USD=60000 # Close jika TVL >= nilai ini (terlalu besar)
TVL_LOW_WARN_USD=2000          # Notif warning jika TVL turun < nilai ini

# ─── FEE & SWAP ──────────────────────────────────────────────────────────────
AUTO_SWAP=true
MAX_SLIPPAGE_BPS=300
FEE_CLAIM_THRESHOLD_SOL=0.03

# ─── COOKIN FILTER ───────────────────────────────────────────────────────────
COOKIN_MIN_SCORE=20
COOKIN_MAX_DUMPERS=60
COOKIN_MAX_BOTS=70
COOKIN_MAX_HOLD_UNDER1MIN=80
COOKIN_MIN_PUMP_CONDITIONS=1
COOKIN_MAX_DUMP_CONDITIONS_PCT=60

# ─── TIMING ──────────────────────────────────────────────────────────────────
CYCLE_INTERVAL_SEC=60          # Interval scan token baru
MONITOR_INTERVAL_SEC=2         # Interval cek posisi aktif (deteksi OOR/SL)
